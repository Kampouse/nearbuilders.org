{
  "name": "@nearbuilders/nostr-comments",
  "version": "0.1.0",
  "description": "Lightweight Nostr-backed comments and news for NEAR Builders projects",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./contract": {
      "types": "./src/contract.ts",
      "default": "./src/contract.ts"
    }
  },
  "peerDependencies": {
    "typescript": "catalog:"
  },
  "scripts": {
    "build": "bun run build:types && rspack build",
    "build:types": "tsc -p tsconfig.contract.json",
    "deploy": "bun run build:types && DEPLOY=true rspack build",
    "dev": "bun run build:types && rspack serve",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "every-plugin": "catalog:",
    "nostr-tools": "^2.10.0",
    "effect": "catalog:",
    "@noble/hashes": "^1.5.0",
    "@noble/curves": "^1.6.0",
    "@scure/base": "catalog:"
  },
  "devDependencies": {
    "@module-federation/node": "catalog:",
    "@rspack/cli": "catalog:",
    "@rspack/core": "catalog:",
    "@tanstack/react-query": "catalog:",
    "@types/node": "catalog:",
    "everything-dev": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "typescript": "catalog:",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "catalog:",
    "zephyr-rspack-plugin": "catalog:"
  }
}
