    "biome": "^1.9.0",
    "bun-types": "^1.1.0",
    "drizzle-kit": "^0.28.0",
    "pglite": "^0.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.6.0"
